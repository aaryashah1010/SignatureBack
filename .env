APP_NAME=Digital Signature Workflow Platform
API_PREFIX=/api
DEBUG=false
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/signature_db
REDIS_URL=redis://redis:6379/0
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
STORAGE_ROOT=/app/storage
CORS_ORIGINS=["http://localhost:5173"]

# ── External Integration (leave blank to disable integration features) ─────────

# SQL Server connection string for reading users and admin→signer mappings.
# Requires pyodbc + ODBC Driver 17 or 18 for SQL Server installed on the host.
# Example: mssql+pyodbc://sa:StrongPass!@sqlserver:1433/ExternalDB?driver=ODBC+Driver+17+for+SQL+Server
SQLSERVER_URL=mssql+pyodbc://sa:Newtech@#1010@69.30.224.78:9759/cpadesk_phase2?driver=ODBC+Driver+17+for+SQL+Server


# Base URL of the external software that will receive completion callbacks.
# Example: https://external-system.example.com
EXTERNAL_API_BASE_URL=

# Pre-shared secret added as X-Auth-Secret header on outbound callback requests.
EXTERNAL_API_AUTH_SECRET=

# HMAC-HS256 secret used to validate signed launch tokens from the external software.
# Must match the secret used by the external software when generating tokens.
INTEGRATION_SHARED_SECRET=ZXNpZ24ubXljcGFkZXNrLmNvbUAyMDI2

# Lifetime of a launch token accepted by the /api/integration/launch endpoint (minutes).
LAUNCH_TOKEN_EXPIRE_MINUTES=15

# How long a used nonce is remembered in Redis to block replay attacks (seconds).
NONCE_TTL_SECONDS=900

# Optional allowlist of path prefixes allowed for external document files.
# Leave empty to disable (not recommended for production).
# Example: ["/mnt/external-docs", "/var/data/documents"]
ALLOWED_DOCUMENT_PATH_PREFIXES=[]
